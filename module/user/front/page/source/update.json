{
  "page": {
    "name": "来源编辑",
    "parent": "user/source/list",
    "sort": 10,
    "auth": [
      {
        "key": "user/source/create",
        "name": "来源新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "user/source/update",
        "name": "来源编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：直播间报名",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "来源名称不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该来源名称已存在，请更换。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
