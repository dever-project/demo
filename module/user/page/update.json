{
  "page": {
    "name": "用户编辑",
    "parent": "user/list",
    "sort": 10,
    "auth": [
      {
        "key": "user/create",
        "name": "用户新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "user/update",
        "name": "用户编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "tabs-row": {
            "type": "container",
            "className": "mb-4"
          },
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "tabs-row": [
      {
        "type": "nav-tab",
        "meta": {
          "target": "state.currentTab",
          "variant": "line",
          "tabs": [
            {
              "label": "基础信息",
              "value": "basic"
            },
            {
              "label": "扩展信息",
              "value": "extra"
            }
          ]
        }
      }
    ],
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "名",
        "placeholder": "例如：小明",
        "value": "form.first_name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-input",
        "name": "姓",
        "placeholder": "例如：张",
        "value": "form.last_name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "姓不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：zhang_xm",
        "value": "form.username",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "用户名不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该用户名已存在，请更换用户名。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：xiaoming@example.com",
        "value": "form.email",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "邮箱不能为空。"
          },
          {
            "type": "email",
            "message": "请输入有效的邮箱地址。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该邮箱已存在，请更换邮箱。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：13800138000",
        "value": "form.phone_number",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "手机号不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-upload",
        "placeholder": "上传头像图片",
        "value": "form.avatar_id",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "uploadType": "pic",
          "ruleId": 1,
          "bizKey": "user.avatar",
          "bizName": "用户头像"
        }
      },
      {
        "id": "user-role",
        "type": "form-select",
        "placeholder": "请选择角色",
        "value": "form.role",
        "mode": "form",
        "option": "option.role",
        "validate": [
          {
            "type": "required",
            "message": "角色不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "controlClassName": "max-w-[188px]",
          "control": [
            {
              "value": "Manager",
              "hide": ["user-source"]
            }
          ]
        }
      },
      {
        "id": "user-source",
        "type": "form-select",
        "placeholder": "请选择来源",
        "value": "form.source_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=user.NewSourceModel",
        "validate": [
          {
            "type": "required",
            "message": "来源不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "输入一句简短介绍，突出当前用户的职责或标签。",
        "info": "demo：保存前会自动去掉首尾空格；如果介绍留空，保存后会自动生成一条默认介绍。",
        "value": "form.intro",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "extra",
          "rows": 4,
          "maxLength": 200,
          "showCount": true
        }
      },
      {
        "type": "form-upload",
        "name": "附件",
        "placeholder": "上传附件文件",
        "value": "form.attachment_ids",
        "mode": "form",
        "info": "附件会按列表形式展示，可连续上传多个文件并支持拖动排序。",
        "meta": {
          "formLayout": "horizontal",
          "tab": "extra",
          "uploadType": "list",
          "ruleId": 6,
          "maxCount": 6,
          "bizKey": "user.attachment",
          "bizName": "用户附件"
        }
      },
      {
        "type": "form-upload",
        "placeholder": "上传用户视频",
        "value": "form.video_id",
        "mode": "form",
        "info": "单个视频字段，使用视频上传规则，可从资源库复用已有视频。",
        "meta": {
          "formLayout": "horizontal",
          "tab": "extra",
          "uploadType": "video",
          "kind": "video",
          "ruleId": 2,
          "maxCount": 1,
          "bizKey": "user.video",
          "bizName": "用户视频"
        }
      },
      {
        "type": "form-upload",
        "name": "音频",
        "placeholder": "上传用户音频",
        "value": "form.audio",
        "mode": "form",
        "info": "音频按卡片形式展示，支持多选、拖动排序，并可从资源库复用已有音频；保存时会写成包含文件名和完整地址的列表。",
        "meta": {
          "formLayout": "horizontal",
          "tab": "extra",
          "uploadType": "audio",
          "kind": "audio",
          "saveMode": "url",
          "ruleId": 3,
          "maxCount": 6,
          "bizKey": "user.audio",
          "bizName": "用户音频"
        }
      },
      {
        "type": "form-editor",
        "placeholder": "输入更完整的说明内容，支持标题、列表、引用等基础排版。",
        "value": "form.content",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "tab": "extra",
          "minHeight": 220
        }
      },
      {
        "type": "form-cascader",
        "placeholder": "请选择地区",
        "value": "form.region_ids",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "地区不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "api": "/front/route/option",
          "type": "model",
          "use": "region.NewRegionModel",
          "parentField": "parent_id",
          "rootValue": 0,
          "placeholder": ["省份", "城市", "区县"],
          "labelTarget": "form.region_names"
        }
      },
      {
        "id": "user-work",
        "type": "form-select",
        "placeholder": "请选择职业",
        "value": "form.work_ids",
        "mode": "form",
        "info": "角色不同，职业会自动按类型筛选。",
        "tip": "当前 demo：经理只显示 IT 类职业，管理员只显示物流类职业。",
        "option": "option.work",
        "validate": [
          {
            "type": "required",
            "message": "职业不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "multiple": true,
          "controlClassName": "max-w-[260px]",
          "optionFilter": [
            {
              "field": "type_id",
              "path": "form.role",
              "map": {
                "Manager": 1,
                "Admin": 2
              }
            }
          ]
        }
      },
      {
        "type": "form-array",
        "value": "form.titles",
        "mode": "form",
        "info": "可录入多个头衔，保存时会和用户信息一起提交。",
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "pageRoute": "/user/title/update",
          "addText": "添加头衔",
          "drag": "sort"
        }
      },
      {
        "type": "form-password",
        "name": "密码",
        "placeholder": "例如：S3cur3P@ssw0rd",
        "value": "form.password",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "密码不能为空。",
            "when": [
              {
                "path": "form.id",
                "operator": "empty"
              }
            ]
          },
          {
            "type": "min",
            "min": 8,
            "message": "密码至少 8 位。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      },
      {
        "type": "form-password",
        "name": "确认密码",
        "placeholder": "再次输入密码",
        "value": "form.confirm_password",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "请再次输入密码。",
            "when": [
              {
                "path": "form.id",
                "operator": "empty"
              },
              {
                "path": "form.password",
                "operator": "notEmpty"
              }
            ],
            "condition": "any"
          },
          {
            "type": "sameAs",
            "target": "form.password",
            "message": "两次输入的密码不一致。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic"
        }
      }
    ]
  },
  "data": {
    "form": {}
  },
  "state": {
    "currentTab": "basic"
  },
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "user.UserUpdateHook.BeforeSaveUserUpdate"
      },
      "after": {
        "type": "service",
        "use": "user.UserUpdateHook.AfterSaveUserUpdate"
      }
    }
  }
}
