{
  "page": {
    "name": "用户详情",
    "parent": "user/list",
    "sort": 11
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "flex flex-col gap-4 p-0",
        "children": {
          "basic-card": {
            "type": "container",
            "className": "rounded-lg border bg-background p-4"
          },
          "relation-card": {
            "type": "container",
            "className": "rounded-lg border bg-background p-4"
          },
          "content-card": {
            "type": "container",
            "className": "rounded-lg border bg-background p-4"
          }
        }
      }
    }
  },
  "nodes": {
    "basic-card": [
      {
        "type": "show-title",
        "value": "page.basicTitle",
        "meta": {
          "variant": "section"
        }
      },
      {
        "type": "media-image",
        "name": "头像",
        "value": "form.avatar.url",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "width": 96,
          "height": 96
        }
      },
      {
        "type": "show-base",
        "value": "form.username",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-base",
        "name": "名",
        "value": "form.first_name",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-base",
        "name": "姓",
        "value": "form.last_name",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-base",
        "value": "form.email",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-base",
        "value": "form.phone_number",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-select",
        "value": "form.role",
        "mode": "form",
        "option": "option.role",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-status",
        "value": "form.status",
        "mode": "form",
        "option": "option.status",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-tag",
        "value": "form.source",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "field": "name"
        }
      },
      {
        "type": "show-base",
        "value": "form.created_at",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "format": "datetime-second"
        }
      }
    ],
    "relation-card": [
      {
        "type": "show-title",
        "value": "page.relationTitle",
        "meta": {
          "variant": "section"
        }
      },
      {
        "type": "show-tag",
        "value": "form.regions",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "field": "name"
        }
      },
      {
        "type": "show-tag",
        "value": "form.works",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "field": "name"
        }
      },
      {
        "type": "show-tag",
        "value": "form.titles",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "field": "name"
        }
      },
      {
        "type": "media-video",
        "name": "视频",
        "value": "form.video.url",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "titlePath": "form.video.name"
        }
      },
      {
        "type": "media-audio",
        "value": "form.audio",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "media-file-list",
        "name": "附件",
        "value": "form.attachments",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ],
    "content-card": [
      {
        "type": "show-title",
        "value": "page.contentTitle",
        "meta": {
          "variant": "section"
        }
      },
      {
        "type": "show-base",
        "value": "form.intro",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "show-rich",
        "value": "form.content",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "page": {
      "basicTitle": {
        "title": "基础信息",
        "description": "这里只展示当前用户的基础资料与媒体信息。"
      },
      "relationTitle": {
        "title": "关联信息",
        "description": "展示来源、地区、职业、头衔以及资源信息。"
      },
      "contentTitle": {
        "title": "补充说明",
        "description": "介绍和内容都按只读形式展示。"
      }
    },
    "form": {}
  },
  "state": {},
  "action": {}
}
