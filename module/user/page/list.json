{
  "page": {
    "name": "用户列表",
    "icon": "users",
    "parent": "tongyong",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "status-tabs": {
            "type": "row",
            "className": "items-center"
          },
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "邀请用户",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm"
        },
        "action": {
          "click": "open-invite-user"
        }
      },
      {
        "type": "show-button-group",
        "name": "导入",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "upload"
        },
        "items": [
          {
            "key": "import-user-list",
            "name": "导入用户",
            "action": {
              "click": {
                "type": "import",
                "uploadRuleId": 4,
                "matchFields": [
                  "username",
                  "email"
                ],
                "matchMode": "any",
                "fields": [
                  {
                    "field": "username",
                    "aliases": [
                      "账号",
                      "登录名"
                    ]
                  },
                  {
                    "field": "first_name",
                    "aliases": [
                      "名"
                    ]
                  },
                  {
                    "field": "last_name",
                    "aliases": [
                      "姓"
                    ]
                  },
                  {
                    "field": "email",
                    "aliases": [
                      "邮箱地址"
                    ]
                  },
                  {
                    "field": "phone_number",
                    "aliases": [
                      "手机号码",
                      "电话"
                    ]
                  },
                  {
                    "field": "work_ids",
                    "missingPolicy": "create",
                    "aliases": [
                      "岗位",
                      "工种"
                    ],
                    "tip": "支持多个职业，自动按名称匹配；可在导入弹窗里切换缺失值处理方式。"
                  },
                  {
                    "field": "source_id",
                    "missingPolicy": "create",
                    "aliases": [
                      "用户来源"
                    ],
                    "tip": "按来源名称匹配；可在导入弹窗里切换缺失值处理方式。"
                  },
                  {
                    "field": "region_ids",
                    "aliases": [
                      "区域",
                      "所属地区"
                    ],
                    "tip": "支持按级联路径匹配地区，例如：北京市、市辖区、朝阳区。"
                  },
                  {
                    "field": "titles",
                    "aliases": [
                      "称号",
                      "标签头衔"
                    ],
                    "tip": "支持多个头衔，导入时会按顺序生成子项。"
                  },
                  {
                    "field": "avatar_id",
                    "aliases": [
                      "头像图片",
                      "头像文件"
                    ],
                    "tip": "支持单元格贴图、绝对路径、相对路径；相对路径默认基于导入文件所在目录解析。"
                  },
                  {
                    "field": "video_id",
                    "aliases": [
                      "视频文件"
                    ],
                    "tip": "支持单元格贴图或文件路径；视频通常建议用路径导入。"
                  },
                  {
                    "field": "audio",
                    "kind": "upload",
                    "multiple": true,
                    "saveMode": "url",
                    "aliases": [
                      "音频文件"
                    ],
                    "tip": "支持一个或多个文件路径；最终会保存为包含文件名和完整地址的列表。"
                  },
                  {
                    "field": "attachment_ids",
                    "aliases": [
                      "文件",
                      "附件文件"
                    ],
                    "tip": "支持文件路径或目录路径；目录会按文件列表批量导入。"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "type": "show-button-group",
        "name": "导出",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "download"
        },
        "items": [
          {
            "key": "export-user-list",
            "name": "导出用户列表",
            "action": {
              "click": {
                "type": "export"
              }
            }
          },
          {
            "key": "export-user-workbook",
            "name": "导出用户职业",
            "action": {
              "click": {
                "type": "export",
                "use": "user.ExportService.PrepareUserWorkbook"
              }
            }
          },
          {
            "key": "export-user-model-all",
            "name": "导出整张用户表",
            "action": {
              "click": {
                "type": "export",
                "source": "model",
                "scope": "all"
              }
            }
          }
        ]
      },
      {
        "type": "show-button",
        "name": "新增用户",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "drawer.open",
            "value": true
          }
        }
      }
    ],
    "status-tabs": [
      {
        "type": "nav-tab",
        "value": "search.status",
        "option": "option.status",
        "mode": "search",
        "meta": {
          "target": "data.search.status",
          "variant": "pill",
          "remoteSearch": true,
          "searchLayoutId": "status-tabs,toolbar-row",
          "queryKey": "status",
          "tabs": [
            {
              "label": "全部",
              "value": "__all__",
              "targetValue": ""
            }
          ]
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "筛选用户...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "角色",
        "value": "search.role",
        "mode": "search",
        "option": "option.role"
      },
      {
        "type": "form-select",
        "placeholder": "职业",
        "value": "search.work_ids",
        "mode": "search",
        "option": "option.work",
        "meta": {
          "multiple": true
        }
      },
      {
        "type": "form-date",
        "placeholder": "创建时间",
        "value": "search.created_at_start",
        "mode": "search",
        "className": "w-[320px]",
        "meta": {
          "range": true,
          "endValue": "search.created_at_end",
          "inputType": "datetime-local"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "searchLayoutId": "status-tabs,toolbar-row",
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "searchLayoutId": "status-tabs,toolbar-row",
          "to": "/user/list"
        }
      }
    ],
    "table-row": [
      {
        "id": "user-table",
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "selectable": true,
          "bulkActions": [
            {
              "icon": "mail",
              "variant": "outline",
              "size": "default",
              "description": "向已选中的用户发送邀请通知。",
              "action": {
                "click": {
                  "type": "request",
                  "api": "/api/users/invite",
                  "method": "post",
                  "params": "$selectedRows"
                }
              }
            },
            {
              "icon": "trash-2",
              "variant": "destructive",
              "size": "default",
              "description": "删除已选中的用户。",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.selectedUsers",
                    "value": "$selectedRows"
                  },
                  {
                    "type": "modal",
                    "key": "confirm.bulkDelete",
                    "value": true
                  }
                ]
              }
            }
          ],
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base",
              "meta": {
                "fixed": "left",
                "width": 72
              }
            },
            {
              "name": "头像",
              "value": "avatar.url",
              "type": "media-image",
              "className": "w-[60px] min-w-[60px] align-middle",
              "meta": {
                "compact": true,
                "width": 50,
                "height": 50
              }
            },
            {
              "tip": "双击后可直接修改并自动保存。",
              "value": "username",
              "type": "show-base",
              "editor": true
            },
            {
              "value": "first_name",
              "type": "show-base",
              "editor": true
            },
            {
              "value": "last_name",
              "type": "show-base",
              "editor": true
            },
            {
              "value": "email",
              "type": "show-base",
              "editor": true
            },
            {
              "value": "phone_number",
              "type": "show-base",
              "editor": true
            },
            {
              "tip": "点击状态可直接切换，修改为已停用时会二次确认。",
              "value": "status",
              "type": "show-select",
              "meta": {
                "display": "badge",
                "confirmValues": ["Suspended"]
              }
            },
            {
              "value": "regions",
              "type": "show-tag",
              "meta": {
                "field": "name"
              }
            },
            {
              "value": "works",
              "type": "show-tag",
              "meta": {
                "field": "name"
              }
            },
            {
              "value": "titles",
              "type": "show-tag",
              "meta": {
                "field": "name"
              }
            },
            {
              "value": "audio",
              "type": "media-audio",
              "className": "min-w-[180px] align-middle",
              "meta": {
                "compact": true,
                "maxVisible": 1
              }
            },
            {
              "name": "视频",
              "value": "video.url",
              "type": "media-video",
              "className": "min-w-[180px] align-middle",
              "meta": {
                "compact": true,
                "titlePath": "video.name"
              }
            },
            {
              "name": "附件",
              "value": "attachments",
              "type": "media-file-list",
              "className": "min-w-[180px] align-middle",
              "meta": {
                "compact": true,
                "maxVisible": 1
              }
            },
            {
              "value": "role",
              "type": "show-select"
            },
            {
              "value": "source",
              "type": "show-tag",
              "meta": {
                "field": "name"
              }
            },
            {
              "name": "测试表格",
              "value": "demo_table",
              "type": "show-table",
              "className": "min-w-[240px]",
              "meta": {
                "columns": [
                  {
                    "name": "测试名",
                    "value": "label",
                    "type": "show-base",
                    "meta": {
                      "align": "left"
                    }
                  },
                  {
                    "name": "测试值",
                    "value": "value",
                    "type": "show-base",
                    "meta": {
                      "align": "left"
                    }
                  }
                ]
              }
            },
            {
              "name": "创建时间",
              "value": "created_at",
              "type": "show-base",
              "className": "min-w-[168px] whitespace-nowrap",
              "meta": {
                "format": "datetime-minute"
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "fixed": "right",
                "width": 224,
                "buttons": [
                  {
                    "icon": "eye",
                    "variant": "outline",
                    "size": "sm",
                    "description": "查看当前用户",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.viewUserId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.view",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "file-text",
                    "variant": "outline",
                    "size": "sm",
                    "description": "查看当前用户的内容列表",
                    "to": "/user/content/list",
                    "searchParam": "user_id",
                    "searchField": "id",
                    "withBack": true
                  },
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前用户",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editUserId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.open",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "xs",
                    "description": "删除当前用户",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteUser",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.view",
          "pageRoute": "/user/view",
          "title": "查看用户",
          "description": "在这里查看当前用户的完整信息。",
          "pageRouteQuery": {
            "id": "data.actionTarget.viewUserId"
          },
          "size": "xl",
          "bodyClassName": "max-h-[65vh] overflow-y-auto px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.open",
          "pageRoute": "/user/update",
          "title": "编辑用户",
          "description": "在这里更新用户信息，完成后点击保存即可。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editUserId"
          },
          "bodyClassName": "h-[420px] px-6 py-1"
        }
      },
      {
        "type": "feedback-drawer",
        "meta": {
          "stateKey": "drawer.open",
          "pageRoute": "/user/update",
          "side": "right",
          "title": "新增用户",
          "description": "在这里创建新用户，完成后点击保存即可。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "drawerClassName": "sm:max-w-xl",
          "bodyClassName": "px-6 py-1"
        }
      },
      {
        "type": "feedback-modal",
        "name": "邀请用户",
        "info": "这里预留邀请用户弹层，用于对齐 shadcn-admin 的 users 页面结构。",
        "meta": {
          "stateKey": "dialog.invite",
          "content": "<div class='rounded-lg border bg-muted/30 p-4 text-sm text-muted-foreground'>邀请弹层下一步再接，这一版先把主结构和主操作入口对齐到 shadcn-admin。</div>",
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "修改状态",
        "info": "确认将状态改为“已停用”吗？",
        "meta": {
          "stateKey": "confirm.statusChange",
          "patchTargetPath": "table.list",
          "patchPayloadPath": "actionTarget.statusChangePayload",
          "patchRowKey": "id",
          "successMessage": "状态修改成功",
          "errorMessage": "状态修改失败"
        },
        "action": {
          "confirm": {
            "type": "save",
            "path": "user/update",
            "params": "actionTarget.statusChangePayload"
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除用户",
        "info": "确认删除当前用户吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": "delete-user"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "批量删除用户",
        "info": "确认删除当前选中的用户吗？",
        "meta": {
          "stateKey": "confirm.bulkDelete"
        },
        "action": {
          "confirm": "delete-users"
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "用户列表",
      "description": "在这里统一管理用户信息和角色权限。"
    },
    "search": {
      "keyword": "",
      "role": "",
      "status": "",
      "work_ids": [],
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "service": "user.UserListService.BuildDemoTable",
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "filterFields": [
        "status",
        "role",
        "work_ids",
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end",
          "valueType": "datetime"
        }
      ],
      "searchFields": [
        "username",
        "first_name",
        "last_name",
        "email",
        "phone_number"
      ]
    },
    "actionTarget": {
      "viewUserId": "",
      "editUserId": "",
      "deleteUser": {},
      "selectedUsers": []
    }
  },
  "state": {
    "confirm": {
      "delete": false,
      "bulkDelete": false
    },
    "dialog": {
      "view": false,
      "open": false,
      "invite": false
    },
    "drawer": {
      "open": false
    }
  },
  "action": {
    "open-invite-user": {
      "type": "modal",
      "key": "dialog.invite",
      "value": true
    },
    "delete-user": {
      "type": "delete",
      "params": "actionTarget.deleteUser"
    },
    "delete-users": {
      "type": "delete",
      "params": "actionTarget.selectedUsers"
    }
  }
}
