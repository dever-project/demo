{
  "page": {
    "name": "内容列表",
    "icon": "file-text",
    "parent": "tongyong",
    "sort": 4
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-rich",
        "value": "page.titleHtml",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回上一页",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "back": true
        }
      },
      {
        "type": "show-button",
        "name": "新增内容",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "筛选标题或内容...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "选择用户",
        "value": "search.user_id",
        "option": "/front/route/option?type=model&use=user.NewUserModel&labelField=username&searchFields=username,first_name,last_name,email,phone_number&pageSize=10",
        "mode": "search",
        "meta": {
          "remoteOptionSearch": true,
          "searchPlaceholder": "输入用户名、姓名或邮箱搜索..."
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/user/content/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "name": "ID",
              "value": "id",
              "type": "show-base",
              "meta": {
                "width": 72
              }
            },
            {
              "name": "用户",
              "value": "user.username",
              "type": "show-base",
              "className": "min-w-[140px]"
            },
            {
              "value": "title",
              "type": "show-base",
              "className": "min-w-[180px]"
            },
            {
              "value": "content",
              "type": "show-rich",
              "className": "min-w-[280px] max-w-[420px]",
              "meta": {
                "preview": true
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "fixed": "right",
                "width": 96,
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑当前内容",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editContentId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "page-main": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/user/content/update",
          "title": "新增内容",
          "description": "在这里给用户新增内容，内容字段支持基础富文本编辑。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "user_id": "data.search.user_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/user/content/update",
          "title": "编辑内容",
          "description": "在这里更新当前内容的标题和正文。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editContentId"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "page": {
      "titleHtml": "<div class='flex min-w-0 flex-col gap-0.5'><h1 class='text-xl font-semibold tracking-tight text-foreground'>内容列表</h1><p class='text-sm leading-6 text-muted-foreground'>按用户维护标题和正文内容，可从用户列表直接进入并默认筛选对应用户。</p></div>"
    },
    "search": {
      "keyword": "",
      "user_id": ""
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "filterFields": [
        "user_id"
      ],
      "searchFields": [
        "title",
        "content"
      ]
    },
    "actionTarget": {
      "editContentId": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    }
  },
  "action": {}
}
