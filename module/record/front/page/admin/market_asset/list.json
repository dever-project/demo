{
  "page": {
    "name": "行情数据",
    "icon": "chart-candlestick",
    "parent": "record-market",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增采集任务",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.createJob",
            "value": true
          }
        }
      },
      {
        "type": "show-button",
        "name": "计划任务",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "icon": "calendar-clock",
          "to": "/front/cron/list"
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "筛选币种名称或符号...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "榜单",
        "value": "search.scope",
        "mode": "search",
        "option": "option.scope",
        "meta": {
          "controlClassName": "w-[140px]"
        }
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search",
        "option": "option.status",
        "meta": {
          "controlClassName": "w-[140px]"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "searchLayoutId": "toolbar-row",
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "searchLayoutId": "toolbar-row",
          "to": "/record/market_asset/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "scope",
              "type": "show-tag",
              "className": "text-center"
            },
            {
              "value": "market_cap_rank",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "symbol",
              "type": "show-base"
            },
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "price",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "market_cap",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "total_volume",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "price_change_percentage_24h",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "source",
              "type": "show-tag",
              "className": "text-center"
            },
            {
              "value": "status",
              "type": "show-tag",
              "className": "text-center"
            },
            {
              "value": "source_updated_at",
              "type": "show-date"
            },
            {
              "value": "collected_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.createJob",
          "pageRoute": "/record/market_job/update",
          "title": "新增行情采集任务",
          "description": "任务保存后会进入系统计划任务，按设定间隔采集 CoinLore 市值榜和 CoinGecko DeFi 行情。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "md",
          "bodyClassName": "py-2"
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "行情数据",
      "description": "查看定时采集的 CoinLore 市值榜和 CoinGecko DeFi 榜行情快照。"
    },
    "search": {
      "keyword": "",
      "scope": "",
      "status": 1
    },
    "table": {
      "searchFields": [
        "symbol",
        "name"
      ],
      "filterFields": [
        "scope",
        "status"
      ],
      "order": "scope asc, market_cap_rank asc, id asc"
    }
  },
  "state": {
    "dialog": {
      "createJob": false
    }
  },
  "action": {}
}
